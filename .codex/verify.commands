# codex-os-managed
# Core repository + governance checks
test -f .codex/codex-os.manifest.json
test -f AGENTS.md

# Environment/toolchain preflight
command -v cargo >/dev/null
command -v pnpm >/dev/null
command -v wasm-pack >/dev/null

# Canonical Rust gates
cargo fmt --check
CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-/tmp/battlegrid-verify-target}" cargo clippy --workspace -- -D warnings
CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-/tmp/battlegrid-verify-target}" cargo test --workspace

# Canonical client gates (path-delimiter safe)
pnpm --prefix client exec tsc -b
pnpm --prefix client exec eslint .
pnpm --prefix client exec vitest run
pnpm --prefix client exec vite build
